rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Parse attachments: only the owner can read/write their own files.
    // Max 10 MB. Allowed MIME types: PDF and images.
    match /users/{userId}/parse_attachments/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('image/.*')
        );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Trip cover images: only the owner can read/write their own covers.
    // Max 5 MB. Images only.
    match /covers/{userId}/{tripId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Travel documents (passport, visa, insurance, etc.): owner-only.
    // Max 20 MB. PDF and images.
    match /users/{userId}/documents/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 20 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('image/.*')
        );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
