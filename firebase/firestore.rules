rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global collections: read-only for any authenticated user.
    // Writes are handled exclusively by Cloud Functions (server-side).
    match /airports/{iataCode} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /fx_rates/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All subcollections under a user's document:
    // trips/{tripId}/cities, trip_days, flights, hotels, transports, parse_jobs
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default (made explicit for clarity)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
