rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global collections: read-only for any authenticated user.
    // Writes are handled exclusively by Cloud Functions (server-side).
    match /airports/{iataCode} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /fx_rates/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Household pattern:
    // A single document `households/main` holds { memberUids: ["uid1", "uid2"] }.
    // This enables Mati and Agustina to share all trip data
    // that lives under the owner's uid subtree, without duplicating documents.
    // Reading the household doc is needed by the rules engine itself (via get()) so
    // any authenticated user must be able to read it.
    // Writes are restricted to existing members only, so only a current member can
    // add the second UID after first login.
    match /households/main {
      allow read: if request.auth != null;
      // Allow creating the doc on first login (bootstrap); allow updating only if already a member.
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids;
      allow delete: if false;
    }

    // Helper: true if the requester is a member of the household.
    // Guards against null when households/main hasn't been created yet.
    function isHouseholdMember() {
      let doc = get(/databases/$(database)/documents/households/main);
      return request.auth != null
          && doc != null
          && request.auth.uid in doc.data.memberUids;
    }

    // User profile document (top-level)
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == userId || isHouseholdMember());
    }

    // All subcollections under a user's document:
    // trips/{tripId}/cities, trip_days, flights, hotels, transports, parse_jobs
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == userId || isHouseholdMember());
    }

    // Explicit collectionGroup rule for cities (needed for cross-trip suggestion queries).
    // The path always lives under users/{userId}/trips/{tripId}/cities/{cityId},
    // so ownership is guaranteed by the parent match above, but Firestore requires
    // a top-level collectionGroup rule when COLLECTION_GROUP indexes are queried.
    match /{path=**}/cities/{cityId} {
      allow read: if request.auth != null && isHouseholdMember();
      allow write: if false; // writes always go through the users/{userId}/... path
    }

    // Deny everything else by default (made explicit for clarity)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
